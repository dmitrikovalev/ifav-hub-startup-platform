# Database — get free PostgreSQL at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname

# AI — single key for Gemini 2.5 Flash Lite + gemini-embedding-001
# Get free key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Auth
SECRET_KEY=change-this-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File Storage — get free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
